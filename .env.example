# ===================================
# SMTP (Email Service — via nodemailer)
# ===================================
# Setup Krealabs : Brevo SMTP (outbound) — la réception reste ProtonMail
# via les MX records OVH. Free tier 300 emails/jour.
#
# Setup Brevo :
#   1. Créer compte sur https://www.brevo.com (free, no card required)
#   2. Senders & IP > Add a domain > krealabs.fr
#   3. Copier les 3 DNS records (DKIM + brevo-code + DMARC) → coller dans OVH
#      Zone DNS (Domain Name & DNS > Zone DNS)
#   4. SMTP & API > SMTP > générer une clé SMTP, la coller dans SMTP_PASS
#   5. Le login SMTP est en haut de la page (souvent l'email du compte)
#
# Variantes pour d'autres providers :
#  • OVH Mail Pro : SMTP_HOST=ssl0.ovh.net   SMTP_PORT=465
#  • Gmail        : SMTP_HOST=smtp.gmail.com SMTP_PORT=587 (App Password requis)
#  • AWS SES      : SMTP_HOST=email-smtp.eu-west-1.amazonaws.com SMTP_PORT=587
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login@example.com
SMTP_PASS=your_brevo_smtp_key_here
SMTP_FROM="Krealabs <noreply@krealabs.fr>"

# Destinataire des formulaires (contact, waitlist notifications, etc.)
# = la boîte ProtonMail qui reçoit (via MX records OVH)
CONTACT_EMAIL=contact@krealabs.fr

# ===================================
# DATABASE (PostgreSQL)
# ===================================
# Your PostgreSQL connection string
# Example with Neon: postgresql://user:password@host.neon.tech/database?sslmode=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ===================================
# NEXT.JS
# ===================================
# Your site URL (required for emails and metadata)
# Development
NEXT_PUBLIC_URL=http://localhost:3000
# Production
# NEXT_PUBLIC_URL=https://krealabs.fr

# ===================================
# ADMIN AUTHENTICATION
# ===================================
# Generate a secure random string for production
# Example: openssl rand -base64 32
ADMIN_TOKEN=your_secure_admin_token_here
