# ===================================
# EMAIL (Resend + domaine vérifié send.krealabs.fr)
# ===================================
# Resend gère l'envoi outbound (notifs + auto-reply).
# La réception reste sur ProtonMail via les MX OVH du domaine racine
# krealabs.fr — aucun conflit, les deux cohabitent.
#
# Setup :
#   1. Créer un compte sur https://resend.com
#   2. Ajouter le domaine send.krealabs.fr → "Enable Sending" uniquement
#   3. Copier les 3 records (SPF + DKIM) dans la zone OVH
#   4. Attendre le statut "Verified" dans Resend
#   5. Créer une API key (Dashboard > API Keys) → RESEND_API_KEY

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Krealabs <noreply@krealabs.fr>
CONTACT_EMAIL=contact@krealabs.fr

# Newsletter — Resend Audience ID (Dashboard Resend > Audiences > Create)
# Sans cette var, les inscriptions sont stockées en DB mais pas synchronisées
# vers Resend Audience (le welcome email part quand même)
RESEND_AUDIENCE_ID=aud_xxxxxxxxxxxxxxxxxxxx

# ===================================
# DATABASE (PostgreSQL)
# ===================================
# Your PostgreSQL connection string
# Example with Neon: postgresql://user:password@host.neon.tech/database?sslmode=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ===================================
# NEXT.JS
# ===================================
NEXT_PUBLIC_URL=http://localhost:3000
# Production : NEXT_PUBLIC_URL=https://krealabs.fr

# ===================================
# ADMIN AUTHENTICATION
# ===================================
# Generate via: openssl rand -base64 32
ADMIN_TOKEN=your_secure_admin_token_here
