# ===================================
# EMAIL (Formsubmit — zéro setup, zéro DNS)
# ===================================
# Le site utilise https://formsubmit.co pour envoyer les emails du
# formulaire de contact + auto-reply visiteur. Pas d'API key, pas de
# domaine à vérifier.
#
# Une seule chose à faire au premier déploiement :
#   1. Soumettre le formulaire de contact une fois (avec un vrai email)
#   2. Formsubmit envoie un email d'activation à CONTACT_EMAIL ci-dessous
#   3. Cliquer le lien d'activation → tous les envois suivants marchent
#
# Variables d'env requises :
CONTACT_EMAIL=contact@krealabs.fr

# ===================================
# DATABASE (PostgreSQL)
# ===================================
# Your PostgreSQL connection string
# Example with Neon: postgresql://user:password@host.neon.tech/database?sslmode=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ===================================
# NEXT.JS
# ===================================
NEXT_PUBLIC_URL=http://localhost:3000
# Production : NEXT_PUBLIC_URL=https://krealabs.fr

# ===================================
# ADMIN AUTHENTICATION
# ===================================
# Generate via: openssl rand -base64 32
ADMIN_TOKEN=your_secure_admin_token_here
